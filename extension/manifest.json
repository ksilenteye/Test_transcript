{
  "manifest_version": 3,
  "name": "Meet Transcript Stream",
  "version": "1.0.0",
  "description": "Streams Google Meet live captions to a local FastAPI backend.",
  "minimum_chrome_version": "114",
  "permissions": ["activeTab", "scripting", "storage", "alarms"],
  "host_permissions": [
    "https://meet.google.com/*",
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Meet Transcript",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["utils.js", "content.js"],
      "css": ["styles/inject.css"],
      "run_at": "document_idle"
    }
  ]
}
